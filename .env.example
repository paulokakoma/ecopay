# Exemplo de Variáveis de Ambiente para EcoPay

# ====================================
# BYBIT API CONFIGURATION
# ====================================

# API Key da sua conta Bybit (encontrada em: Account → API)
BYBIT_API_KEY=your_api_key_here

# API Secret da sua conta Bybit (encontrado em: Account → API)
BYBIT_API_SECRET=your_api_secret_here

# Usar testnet da Bybit para desenvolvimento (true ou false)
# IMPORTANTE: Testnet usa fundos fictícios - ideal para testes
BYBIT_TESTNET=false

# Modo simulação: true = simula transferências sem chamar API real
# Útil para desenvolvimento e testes
MOCK_BYBIT=false

# ====================================
# SUPABASE CONFIGURATION
# ====================================

# URL do projeto Supabase
SUPABASE_URL=your_supabase_url_here

# API Key do Supabase (encontrada em: Project Settings → API)
SUPABASE_KEY=your_supabase_key_here

# ====================================
# SERVER CONFIGURATION
# ====================================

# Porta do servidor
PORT=3001

# Ambiente (development, production, test)
NODE_ENV=development

# ====================================
# EXCHANGE RATES & FEES
# ====================================

# Taxa de câmbio USDT para AOA (Angolan Kwanza)
USDT_AOA_RATE=1200

# Taxa de rede para saques (em USDT)
NETWORK_FEE_USDT=1

# ====================================
# PAYPAY AFRICA (Opcional)
# ====================================

# Credenciais da PayPay Africa (se usar integração)
PAYPAY_API_KEY=your_paypay_key_here
PAYPAY_API_SECRET=your_paypay_secret_here

# ====================================
# CORS & SECURITY
# ====================================

# Origens permitidas para CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://ecopay.com

# ====================================
# LOGGING (Opcional)
# ====================================

# Nível de log: error, warn, info, debug
LOG_LEVEL=info

# Salvar logs em arquivo: true ou false
LOG_TO_FILE=false

# ====================================
# INSTRÇÕES DE CONFIGURAÇÃO
# ====================================

# 1. Renomeie este arquivo para .env
#    mv .env.example .env

# 2. Preencha com suas credenciais reais
#    - BYBIT_API_KEY e BYBIT_API_SECRET de Bybit
#    - SUPABASE_URL e SUPABASE_KEY de Supabase

# 3. NÃO commite o arquivo .env no git!
#    (Já está em .gitignore)

# 4. Para desenvolvimento, use MOCK_BYBIT=true para não gastar
#    saldo real durante os testes

# ====================================
# COMO OBTER AS CREDENCIAIS
# ====================================

# BYBIT:
# 1. Faça login em https://www.bybit.com
# 2. Vá para Account → My Wallet → API (ou Users → My API)
# 3. Clique em "Create API Key"
# 4. Selecione "System Generated" ou "Self-Generated"
# 5. Defina permissões (Trade, Wallet Read, Transfer)
# 6. Copie API Key e API Secret
#    ⚠️ O Secret só é mostrado uma vez! Salve num lugar seguro

# SUPABASE:
# 1. Vá para https://supabase.com
# 2. Faça login na sua conta
# 3. Vá para o seu projeto
# 4. Clique em "Settings" → "API"
# 5. Copie URL e anon (public) key

# ====================================
# EXEMPLOS DE VALORES
# ====================================

# Exemplo Real (NUNCA commite isto!):
# BYBIT_API_KEY=XXXXXXXXXXXXXXXXXXXXXXX
# BYBIT_API_SECRET=YYYYYYYYYYYYYYYYYYYYYYY

# Exemplo para Desenvolvimento (seguro):
# MOCK_BYBIT=true
# BYBIT_API_KEY=mock_key
# BYBIT_API_SECRET=mock_secret

# ====================================
# CHECKLIST ANTES DE USAR
# ====================================

# ✅ Renomeou .env.example para .env?
# ✅ Preencheu BYBIT_API_KEY e BYBIT_API_SECRET?
# ✅ Preencheu SUPABASE_URL e SUPABASE_KEY?
# ✅ .env está em .gitignore?
# ✅ Testou com MOCK_BYBIT=true primeiro?
# ✅ NODE_ENV está como "development" para testes?
# ✅ Não commitou o arquivo .env?

# ====================================
# SEGURANÇA
# ====================================

# ⚠️  IMPORTANTE:
# - NUNCA exponha suas API Keys públicas
# - NUNCA pushe o arquivo .env para repositórios públicos
# - NUNCA compartilhe suas credenciais
# - Regenere as chaves se houver suspeita de vazamento
# - Use permissões mínimas necessárias na API Bybit

# Para Bybit, recomendo:
# - ✅ Habilitar "Wallet Read"
# - ✅ Habilitar "Transfer" (apenas saque)
# - ❌ Desabilitar "Trade"
# - ❌ Desabilitar alteração de permissões

# ====================================
